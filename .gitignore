# Lokale test-fixtures voor parser-tests (real-data snapshots + CSVs)
# Tests staan wel in git, fixtures niet. Tests skippen automatisch wanneer
# fixture-files ontbreken zodat CI op GitHub blijft slagen.
tests/_fixtures/

# Local backups + scratch
/backups/
_scratch/

# Playwright test infrastructure
playwright-report/
test-results/
# Alleen baseline-screenshots committen, geen one-off output
tests/screenshots/**/*.png
!tests/screenshots/baseline/
!tests/screenshots/baseline/**
